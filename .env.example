# Frontend
VITE_API_URL=

# Backend (API)
# LLM Provider: openai | gemini | claude | nvidia
LLM_PROVIDER=nvidia

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Anthropic Claude
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-3-haiku-20240307
CLAUDE_BASE_URL=

# NVIDIA
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Processing
BATCH_SIZE=20
MAX_CONCURRENT_BATCHES=3
MAX_RETRIES=3
REQUEST_TIMEOUT_MS=120000
RETRY_BASE_DELAY_MS=1000
JOB_TTL_MS=3600000
CLEANUP_INTERVAL_MS=300000
MAX_FILE_SIZE_MB=50
ALLOWED_MIME_TYPES=text/csv,application/csv,text/plain
NODE_ENV=production